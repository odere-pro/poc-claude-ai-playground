# === REQUIRED ===
# Anthropic API key for model inference in the app
ANTHROPIC_API_KEY=

# ngrok authtoken for exposing localhost to judges
NGROK_AUTHTOKEN=

# === OPTIONAL: Model provider ===
# Set to "true" to use AWS Bedrock instead of direct API
# ANTHROPIC_BEDROCK=

# === OPTIONAL: Image generation ===
# Gemini API key for pitch presentation images
# GEMINI_API_KEY=

# === OPTIONAL: Designer on team ===
# Figma personal access token for design-to-code
# FIGMA_PERSONAL_ACCESS_TOKEN=

# === OPTIONAL: AWS extensions ===
# AWS credentials for S3, DynamoDB, Lambda
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-1

# === OPTIONAL: Error tracking ===
# Sentry DSN for runtime error reporting
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# === OPTIONAL: ECC configuration ===
# Hook intensity: minimal | standard | strict
ECC_HOOK_PROFILE=minimal
# Disable specific hooks (comma-separated)
# ECC_DISABLED_HOOKS=
