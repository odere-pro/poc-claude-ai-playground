{
  "id": "nl-part-time",
  "title": "Part-time employment",
  "jurisdiction": "nl",
  "applicable_rule_ids": [
    "nl-trial-period",
    "nl-non-compete",
    "nl-notice-period",
    "nl-working-hours",
    "nl-minimum-wage",
    "nl-overtime-waiver",
    "nl-leave-waiver",
    "nl-written-statement"
  ],
  "mandatory_clauses": [
    { "id": "parties",            "description": "Full names and addresses of both employer and employee" },
    { "id": "start-date",         "description": "Employment start date" },
    { "id": "job-description",    "description": "Job title and responsibilities" },
    { "id": "place-of-work",      "description": "Primary place of work" },
    { "id": "scheduled-hours",    "description": "Exact days and hours the employee is scheduled to work each week" },
    { "id": "gross-salary",       "description": "Pro-rata gross salary and payment frequency" },
    { "id": "notice-period",      "description": "Notice period for both employer and employee" },
    { "id": "holiday-entitlement","description": "Pro-rata holiday entitlement (minimum 4 × scheduled weekly hours)" },
    { "id": "holiday-allowance",  "description": "Vakantiegeld of at least 8% of gross salary" }
