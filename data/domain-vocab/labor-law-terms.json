  "key_concepts": {
    "nl": [
      {
        "term": "vakantiegeld",
        "en": "holiday allowance",
        "note": "Minimum 8% of gross annual salary, paid annually (usually May/June)"
      },
      {
        "term": "transitievergoeding",
        "en": "transition payment",
        "note": "Severance pay on dismissal — 1/3 month salary per year worked"
      },
      {
        "term": "proeftijd",
        "en": "probation period",
        "note": "Max 1 month (fixed-term <2y), max 2 months (indefinite). Must be equal for both parties"
      },
      {
        "term": "concurrentiebeding",
        "en": "non-compete clause",
        "note": "Must be in writing. For indefinite contracts requires motivation. Courts can annul disproportionate clauses"
      },
      {
        "term": "relatiebeding",
        "en": "non-solicitation clause",
        "note": "Restriction on approaching former clients/employees after employment ends"
      },
      {
        "term": "geheimhoudingsbeding",
        "en": "confidentiality clause",
        "note": "Unlimited duration is overbroad; should specify categories and duration"
      },
      {
        "term": "ontslag op staande voet",
        "en": "summary dismissal",
        "note": "Immediate termination without notice — requires urgent cause"
      },
      {
        "term": "kennismigrant",
        "en": "highly skilled migrant",
        "note": "Salary threshold requirement — employer must pay above IND minimum (2025: ~€5,688/month)"
      },
      {
        "term": "oproepcontract",
        "en": "zero-hours contract",
        "note": "Must offer fixed hours after 12 months if consistent work pattern"
      },
      {
        "term": "uitzendovereenkomst",
        "en": "temp agency contract",
        "note": "Phase system: A (flexible), B (fixed-term), C (indefinite)"
      },
      {
        "term": "payroll",
        "en": "payrolling",
        "note": "Worker employed by payroll company but works for user company — extra protections apply"
      },
      {
        "term": "ZZP",
        "en": "self-employed / freelancer",
        "note": "No employment contract — risk of bogus self-employment if employer controls work"
      },
      {
        "term": "loondoorbetaling",
        "en": "continued wage payment",
        "note": "Employer must pay 70% (min. minimum wage) during sickness for up to 2 years"
      },
      {
        "term": "onregelmatigheidstoeslag",
        "en": "irregular hours allowance",
        "note": "Supplement for evening, night, and weekend work — often CAO-regulated"
      },
      {
        "term": "overwerk",
        "en": "overtime",
        "note": "No statutory right to overtime pay unless agreed or via CAO"
      },
      {
        "term": "studiekostenbeding",
        "en": "training cost clause",
        "note": "Repayment obligation for employer-paid training — courts scrutinise proportionality"
      },
      {
        "term": "boetebeding",
        "en": "penalty clause",
        "note": "Fine for breach of contract terms — max €909 per violation unless employer"
      },
      {
        "term": "ketenbepaling",
        "en": "chain rule",
        "note": "Max 3 fixed-term contracts or 3 years before automatic indefinite contract"
      }
    ],
    "se": [
      {
        "term": "provanställning",
        "en": "probation employment",
        "note": "Max 6 months. Either party can terminate without reason during trial period"
      },
      {
        "term": "tillsvidareanställning",
        "en": "indefinite employment",
        "note": "Standard permanent contract — strong dismissal protections under LAS"
      },
      {
        "term": "visstidsanställning",
        "en": "fixed-term employment",
        "note": "Max 2 years total (ALVA rules). Converts to indefinite after threshold"
      },
      {
        "term": "turordning",
        "en": "redundancy seniority",
        "note": "Last in, first out rule — can be modified by collective agreement"
      },
      {
        "term": "saklig grund",
        "en": "objective grounds",
        "note": "Required justification for dismissal under LAS"
      },
      {
        "term": "konkurrensklausul",
        "en": "non-compete clause",
        "note": "Must be proportionate and compensated; industry guidelines limit to 9-18 months"
      },
      {
        "term": "lojalitetsplikt",
        "en": "duty of loyalty",
        "note": "Implied obligation not to work against employer's interests during employment"
      },
      {
        "term": "semesterersättning",
        "en": "holiday pay",
        "note": "12% of gross salary if not paid as part of monthly salary"
      },
      {
        "term": "föräldraledighet",
        "en": "parental leave",
        "note": "480 days shared parental leave under PBL — employer cannot refuse"
      },
      {
        "term": "sjuklön",
        "en": "sick pay",
        "note": "80% of salary, paid by employer for first 14 days"
      },
      {
        "term": "IBA-tak",
        "en": "IBA pension ceiling",
        "note": "Pension contributions typically split: higher % above 7.5x IBA (income base amount)"
      },
      {
        "term": "uppsägningstid",
        "en": "notice period",
        "note": "LAS minimum: 1-6 months based on tenure. Employer cannot require more from employee than employee from employer"
      },
      {
        "term": "varsel",
        "en": "advance notice of redundancy",
        "note": "Statutory notice to Employment Service (Arbetsförmedlingen) for collective redundancies"
      }
    ]
  },

