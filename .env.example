# === REQUIRED ===
# Anthropic API key for clause analysis + voice intent classification
ANTHROPIC_API_KEY=

# === REQUIRED for Solvimon billing integration ===
# https://solvimon.com — entitlement check + usage reporting
SOLVIMON_API_KEY=

# === P1: Voice navigation (optional in P0) ===
# Reson8 STT (speech-to-text) — required when NEXT_PUBLIC_VOICE_ENABLED=true
RESON8_API_KEY=
RESON8_MODEL_ID=

# Toggle voice UI on/off; must be 'true' to enable mic + speak tab
NEXT_PUBLIC_VOICE_ENABLED=false

# === OPTIONAL: Image generation ===
# Gemini API key for pitch presentation images
# GEMINI_API_KEY=

# === OPTIONAL: Designer on team ===
# Figma personal access token for design-to-code
# FIGMA_PERSONAL_ACCESS_TOKEN=

# === OPTIONAL: Error tracking ===
# Sentry DSN for runtime error reporting
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# === OPTIONAL: ECC configuration ===
# Hook intensity: minimal | standard | strict
ECC_HOOK_PROFILE=minimal
# Disable specific hooks (comma-separated)
# ECC_DISABLED_HOOKS=
