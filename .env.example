# === REQUIRED ===
# Anthropic API key for Claude (analysis + voice intent)
ANTHROPIC_API_KEY=

# === REQUIRED for billing gate (P0) ===
# Solvimon billing — entitlement checks + usage reporting
SOLVIMON_API_KEY=
SOLVIMON_TEST_CUSTOMER_ID=
SOLVIMON_CHECKOUT_URL_INDIVIDUAL=

# === OPTIONAL: Voice features (P1) ===
# Gate voice UI + endpoints. Set to "true" to enable.
NEXT_PUBLIC_VOICE_ENABLED=false
# Reson8 STT for transcription
RESON8_API_KEY=
RESON8_MODEL_ID=

# === OPTIONAL: Image generation ===
# Gemini API key for pitch presentation images
# GEMINI_API_KEY=

# === OPTIONAL: Error tracking ===
# Sentry DSN for runtime error reporting
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# === OPTIONAL: ECC configuration ===
# Hook intensity: minimal | standard | strict
ECC_HOOK_PROFILE=minimal
# Disable specific hooks (comma-separated)
# ECC_DISABLED_HOOKS=
