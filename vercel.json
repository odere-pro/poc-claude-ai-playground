{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/analyze/route.ts": { "maxDuration": 120 },
    "src/app/api/transcribe/route.ts": { "maxDuration": 30 },
    "src/app/api/voice-command/route.ts": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
